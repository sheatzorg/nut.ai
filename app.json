{
  "expo": {
    "name": "nutai-main",
    "slug": "nutai-main",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "extra": {
      "nutrientsDb": "./assets/nutrients.db"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.arkabhowal.nutai",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "This app uses speech recognition to log food items.",
        "NSMicrophoneUsageDescription": "This app uses the microphone to recognize food items."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.arkabhowal.nutai",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      [
        "expo-file-system",
        {
          "photosPermission": "Allow Nut.ai to access your photos for meal scanning."
        }
      ],
      "react-native-fast-tflite",
      "expo-speech-recognition"
    ]
  }
}
